<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.DashboardController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Sistema Punto de Venta"/>

    <Label text="Bienvenido Administrador"/>

    <Button text="Productos"
            onAction="#abrirProductos"/>
    <Button text="Ventas"
            onAction="#abrirVentas"/>
    <Button text="Categorías"
            onAction="#abrirCategorias"/>
    <Button text="Proveedores"
            onAction="#abrirProveedores"/>
    <Button text="Compras"
            onAction="#abrirCompras"/>

    <Label fx:id="lblProductos"/>
    <Label fx:id="lblVentas"/>
    <Label fx:id="lblCompras"/>

</VBox>