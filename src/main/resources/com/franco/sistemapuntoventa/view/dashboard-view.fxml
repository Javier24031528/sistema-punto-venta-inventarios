<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.Region?>

<VBox alignment="TOP_CENTER"
      spacing="0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.DashboardController"
      styleClass="main-container"
      stylesheets="@estilos.css"
      prefHeight="600" prefWidth="800">


    <HBox alignment="CENTER_LEFT" spacing="15" style="-fx-background-color: -fx-secondary; -fx-padding: 8 20;">
        <Label text="SISTEMA PUNTO DE VENTA Y CONTROL DE INVENTARIOS" style="-fx-text-fill: white; -fx-font-size: 16; -fx-font-weight: bold;"/>
        <Region HBox.hgrow="ALWAYS"/>
        <Label text="Usuario: Administrador" style="-fx-text-fill: #ecf0f1; -fx-font-size: 12;"/>
    </HBox>

    <HBox spacing="15" VBox.vgrow="ALWAYS" style="-fx-padding: 15;">
        

        <VBox spacing="5" styleClass="card" prefWidth="180" minWidth="180" alignment="TOP_CENTER">
            <Label text="MENÚ" styleClass="subtitle-label" style="-fx-padding: 0 0 5 0;"/>
            
            <Button text="Productos" onAction="#abrirProductos" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
            <Button text="Ventas" onAction="#abrirVentas" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
            <Button text="Categorías" onAction="#abrirCategorias" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
            <Button text="Proveedores" onAction="#abrirProveedores" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
            <Button text="Compras" onAction="#abrirCompras" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
            <Button text="Reportes" onAction="#abrirReportes" maxWidth="Infinity" styleClass="button-secondary" style="-fx-font-size: 12;"/>
        </VBox>


        <VBox spacing="15" HBox.hgrow="ALWAYS">
            <Label text="Indicadores" styleClass="title-label" style="-fx-padding: 0;"/>
            
            <HBox spacing="15">
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" minHeight="80">
                    <Label text="Productos" styleClass="subtitle-label" style="-fx-font-size: 13;"/>
                    <Label fx:id="lblProductos" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: -fx-primary;" text="0"/>
                </VBox>
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" minHeight="80">
                    <Label text="Ventas" styleClass="subtitle-label" style="-fx-font-size: 13;"/>
                    <Label fx:id="lblVentas" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: -fx-accent;" text="0"/>
                </VBox>
                <VBox spacing="8" styleClass="card" HBox.hgrow="ALWAYS" alignment="CENTER" minHeight="80">
                    <Label text="Compras" styleClass="subtitle-label" style="-fx-font-size: 13;"/>
                    <Label fx:id="lblCompras" style="-fx-font-size: 14; -fx-font-weight: bold; -fx-text-fill: -fx-danger;" text="0"/>
                </VBox>
            </HBox>
            
            <VBox styleClass="card" VBox.vgrow="ALWAYS" alignment="CENTER" spacing="5">
                <Label text="Bienvenido al Sistema de Gestión" style="-fx-font-size: 14; -fx-text-fill: -fx-secondary; -fx-font-weight: bold;"/>
                <Label text="Seleccione una opción del menú lateral para comenzar a trabajar." style="-fx-font-size: 12; -fx-text-fill: #95a5a6;"/>
            </VBox>
        </VBox>
    </HBox>

</VBox>