<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.CompraController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Registro de Compras"/>

    <HBox spacing="10">
        <TextField fx:id="txtIdCompra" promptText="ID Compra"/>
        <TextField fx:id="txtIdDetalle" promptText="ID Detalle"/>
    </HBox>

    <HBox spacing="10">
        <ComboBox fx:id="cmbProveedor" promptText="Proveedor"/>
        <ComboBox fx:id="cmbProducto" promptText="Producto"/>
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="txtCantidad" promptText="Cantidad"/>
        <TextField fx:id="txtCostoUnitario" promptText="Costo unitario"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Registrar compra" onAction="#registrarCompra"/>
        <Button text="Limpiar" onAction="#limpiarCampos"/>
    </HBox>

</VBox>
