<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.ProductoController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Gestión de Productos"/>

    <HBox spacing="10">
        <TextField fx:id="txtIdProducto" promptText="ID"/>
        <TextField fx:id="txtCodigoBarras" promptText="Código de barras"/>
        <TextField fx:id="txtNombre" promptText="Nombre"/>
    </HBox>

    <HBox spacing="10">
        <TextField fx:id="txtPrecioVenta" promptText="Precio"/>
        <TextField fx:id="txtStockActual" promptText="Stock"/>
        <ComboBox fx:id="cmbCategoria" promptText="Categoría"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Guardar" onAction="#guardarProducto"/>
        <Button text="Actualizar" onAction="#actualizarProducto"/>
        <Button text="Eliminar" onAction="#eliminarProducto"/>
        <Button text="Limpiar" onAction="#limpiarCampos"/>
    </HBox>

    <TableView fx:id="tablaProductos">
        <columns>
            <TableColumn fx:id="colId" text="ID"/>
            <TableColumn fx:id="colCodigo" text="Código"/>
            <TableColumn fx:id="colNombre" text="Nombre"/>
            <TableColumn fx:id="colPrecio" text="Precio"/>
            <TableColumn fx:id="colStock" text="Stock"/>
            <TableColumn fx:id="colCategoria" text="Categoría"/>
        </columns>
    </TableView>

</VBox>