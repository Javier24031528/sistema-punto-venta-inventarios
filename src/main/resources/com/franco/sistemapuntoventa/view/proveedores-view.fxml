<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.ProveedorController"
      styleClass="main-container"
      stylesheets="@estilos.css"
      prefHeight="450" prefWidth="700">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="←" onAction="#regresarDashboard" styleClass="button-secondary" style="-fx-font-size: 11;"/>
        <Label text="Proveedores" styleClass="title-label" style="-fx-padding: 0;"/>
    </HBox>

    <HBox spacing="10" VBox.vgrow="ALWAYS">
        <!-- Formulario -->
        <VBox spacing="8" styleClass="card" minWidth="220" maxWidth="260">
            <Label text="Datos" styleClass="subtitle-label" style="-fx-font-size: 13;"/>
            
            <VBox spacing="2">
                <Label text="ID" style="-fx-font-size: 11;"/>
                <TextField fx:id="txtIdProveedor" editable="false" style="-fx-background-color: #eee; -fx-font-size: 11;"/>
            </VBox>
            
            <VBox spacing="2">
                <Label text="Razón Social" style="-fx-font-size: 11;"/>
                <TextField fx:id="txtRazonSocial" promptText="Nombre" style="-fx-font-size: 11;"/>
            </VBox>
            
            <VBox spacing="2">
                <Label text="Teléfono" style="-fx-font-size: 11;"/>
                <TextField fx:id="txtTelefono" promptText="999888777" style="-fx-font-size: 11;"/>
            </VBox>

            <VBox spacing="5" style="-fx-padding: 5 0 0 0;">
                <HBox spacing="5">
                    <Button text="Guardar" onAction="#guardarProveedor" styleClass="button-success" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 11;"/>
                    <Button text="Actualizar" onAction="#actualizarProveedor" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 11;"/>
                </HBox>
                <HBox spacing="5">
                    <Button text="Eliminar" onAction="#eliminarProveedor" styleClass="button-danger" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 11;"/>
                    <Button text="Limpiar" onAction="#limpiarCampos" styleClass="button-secondary" HBox.hgrow="ALWAYS" maxWidth="Infinity" style="-fx-font-size: 11;"/>
                </HBox>
            </VBox>
        </VBox>

        <!-- Tabla -->
        <VBox spacing="5" HBox.hgrow="ALWAYS">
            <TableView fx:id="tablaProveedores" VBox.vgrow="ALWAYS" style="-fx-font-size: 11;">
                <columnResizePolicy>
                    <TableView fx:constant="CONSTRAINED_RESIZE_POLICY"/>
                </columnResizePolicy>
                <columns>
                    <TableColumn fx:id="colIdProveedor" text="ID" prefWidth="60"/>
                    <TableColumn fx:id="colRazonSocial" text="Razón Social" prefWidth="250"/>
                    <TableColumn fx:id="colTelefono" text="Teléfono" prefWidth="120"/>
                </columns>
            </TableView>
        </VBox>
    </HBox>

</VBox>