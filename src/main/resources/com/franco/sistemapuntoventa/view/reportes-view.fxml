<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.layout.VBox?>
<?import javafx.scene.layout.HBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.ReporteController"
      styleClass="main-container"
      stylesheets="@estilos.css"
      prefHeight="500" prefWidth="700">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <HBox alignment="CENTER_LEFT" spacing="10">
        <Button text="←" onAction="#regresarDashboard" styleClass="button-secondary" style="-fx-font-size: 11;"/>
        <Label text="Reportes" styleClass="title-label" style="-fx-padding: 0;"/>
    </HBox>

    <VBox spacing="10" VBox.vgrow="ALWAYS">
        <HBox spacing="10" alignment="CENTER_LEFT" styleClass="card">
            <Label text="Tipo:" styleClass="subtitle-label" style="-fx-font-size: 12;"/>
            <ComboBox fx:id="cmbTipoReporte" promptText="Seleccionar" prefWidth="200" style="-fx-font-size: 11;"/>
            <Button text="Generar" onAction="#generarReporte" styleClass="button-success" prefHeight="30" style="-fx-font-size: 11;"/>
        </HBox>

        <VBox spacing="5" VBox.vgrow="ALWAYS" styleClass="card">
            <Label text="Vista Previa" styleClass="subtitle-label" style="-fx-font-size: 12;"/>
            <TextArea fx:id="txtReporte" VBox.vgrow="ALWAYS" editable="false" 
                      style="-fx-font-family: 'Consolas', monospace; -fx-font-size: 11;"/>
        </VBox>
    </VBox>

</VBox>