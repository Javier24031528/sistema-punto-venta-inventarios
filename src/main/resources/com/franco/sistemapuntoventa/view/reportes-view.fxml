<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.ComboBox?>
<?import javafx.scene.control.TextArea?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.ReporteController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <ComboBox fx:id="cmbTipoReporte" promptText="Seleccionar reporte"/>

    <Button text="Generar reporte" onAction="#generarReporte"/>

    <TextArea fx:id="txtReporte" prefHeight="300"/>

</VBox>