<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.PasswordField?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.VBox?>

<VBox alignment="CENTER"
      spacing="15.0"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.LoginController">

    <padding>
        <Insets top="30" right="30" bottom="30" left="30"/>
    </padding>

    <Label text="Sistema Punto de Venta"/>

    <TextField fx:id="txtUsuario"
               promptText="Usuario"/>

    <PasswordField fx:id="txtContrasena"
                   promptText="Contraseña"/>

    <Button text="Iniciar sesión"
            onAction="#iniciarSesion"/>

</VBox>