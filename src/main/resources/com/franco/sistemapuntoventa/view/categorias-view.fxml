<?xml version="1.0" encoding="UTF-8"?>

<?import javafx.geometry.Insets?>
<?import javafx.scene.control.Button?>
<?import javafx.scene.control.Label?>
<?import javafx.scene.control.TableColumn?>
<?import javafx.scene.control.TableView?>
<?import javafx.scene.control.TextField?>
<?import javafx.scene.layout.HBox?>
<?import javafx.scene.layout.VBox?>

<VBox spacing="10"
      xmlns:fx="http://javafx.com/fxml"
      fx:controller="com.franco.sistemapuntoventa.controller.CategoriaController">

    <padding>
        <Insets top="15" right="15" bottom="15" left="15"/>
    </padding>

    <Label text="Gestión de Categorías"/>

    <HBox spacing="10">
        <TextField fx:id="txtIdCategoria" promptText="ID"/>
        <TextField fx:id="txtNombreCategoria" promptText="Nombre de categoría"/>
    </HBox>

    <HBox spacing="10">
        <Button text="Guardar" onAction="#guardarCategoria"/>
        <Button text="Actualizar" onAction="#actualizarCategoria"/>
        <Button text="Eliminar" onAction="#eliminarCategoria"/>
        <Button text="Limpiar" onAction="#limpiarCampos"/>
    </HBox>

    <TableView fx:id="tablaCategorias">
        <columns>
            <TableColumn fx:id="colIdCategoria" text="ID"/>
            <TableColumn fx:id="colNombreCategoria" text="Categoría"/>
        </columns>
    </TableView>

    <Button text="Regresar"
            onAction="#regresarDashboard"/>

</VBox>